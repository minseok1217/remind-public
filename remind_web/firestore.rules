rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function familyLinkId(guardianId, patientId) {
      return guardianId + "_" + patientId;
    }

    function isGuardianOfPatient(guardianId, patientId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/family_links/$(familyLinkId(guardianId, patientId)));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (request.auth.uid == userId || isGuardianOfPatient(request.auth.uid, userId));

      match /photos/{photoId} {
        allow read, write: if isSignedIn();
      }
    }

    match /guardians/{guardianId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == guardianId;
    }

    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (request.auth.uid == patientId || isGuardianOfPatient(request.auth.uid, patientId));

      match /notification_tokens/{tokenId} {
        allow read, write: if isSignedIn()
          && (request.auth.uid == patientId || isGuardianOfPatient(request.auth.uid, patientId));
      }
    }

    match /family_links/{linkId} {
      allow read, create, update, delete: if isSignedIn();
    }

    match /temp_codes/{codeId} {
      allow read, delete: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.patient_id == request.auth.uid
        && request.resource.data.code == codeId
        && request.resource.data.expires_at is timestamp;
    }

    match /call_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /photos/{photoId} {
      allow read, write: if isSignedIn();
    }

    match /guardians/{guardianId}/photos/{photoId} {
      allow read, write: if isSignedIn();
    }

    match /Memories/{memoryId} {
      allow read, write: if isSignedIn();
    }

    match /Call/{callId} {
      allow read, write: if isSignedIn();
    }

    match /Conversation/{logId} {
      allow read, write: if isSignedIn();
    }

    match /Report/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /cognitive_scores/{scoreId} {
      allow read, write: if isSignedIn();
    }

    match /orientation_images/{docId} {
      allow read: if isSignedIn();
    }

    match /orientation_questions/{docId} {
      allow read: if isSignedIn();
    }
  }
}
